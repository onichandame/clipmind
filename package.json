{
  "name": "clipmind-workspace",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:desktop": "pnpm --filter desktop dev",
    "build:desktop": "pnpm --filter desktop build",
    "tauri:dev": "pnpm --filter desktop exec tauri dev",
    "tauri:build": "pnpm --filter desktop exec tauri build",
    "dev": "concurrently -k -c \"cyan,magenta\" -n \"🚀 Tauri,🧠 API\" \"pnpm run tauri:dev\" \"pnpm --filter server dev\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
